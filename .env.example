# ---------------------------------------------------------------------------
# PhonePe Payment Gateway (Standard Checkout / Salt Key flow)
# ---------------------------------------------------------------------------
# Copy this file to `.env.local` and fill in your LIVE values before going live.
# `.env.local` is git-ignored — never commit real Salt Keys.
#
# If these are left unset, the app falls back to PhonePe's PUBLIC UAT sandbox
# (test merchant, no real money) so you can exercise the flow locally.

# Your live Merchant ID from the PhonePe Business dashboard
PHONEPE_MERCHANT_ID=

# Your live Salt Key (SECRET — treat like a password, never share or commit)
PHONEPE_SALT_KEY=

# Your live Salt Index (usually 1)
PHONEPE_SALT_INDEX=1

# PhonePe API host:
#   Production : https://api.phonepe.com/apis/hermes
#   UAT/Sandbox: https://api-preprod.phonepe.com/apis/pre-prod
PHONEPE_HOST=https://api.phonepe.com/apis/hermes

# Public origin of the deployed site — used to build PhonePe redirect/callback
# URLs. Must be publicly reachable in production (localhost won't receive the
# async server-to-server callback).
APP_BASE_URL=https://invitemart.in

# ---------------------------------------------------------------------------
# Database (Postgres) — customer + order store
# ---------------------------------------------------------------------------
# Any standard Postgres works: Neon (recommended, free), Supabase, Vercel
# Postgres, Railway. Use the provider's POOLED connection string for serverless.
# Example (Neon): postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=
